# ── Ollama ──────────────────────────────────────────
# Which local model to use for parsing receipt text
OLLAMA_MODEL=llama3.2

# URL where Ollama is running (default is usually fine)
OLLAMA_URL=http://localhost:11434

# ── OCR ─────────────────────────────────────────────
# Language for Tesseract (swe = Swedish, eng = English)
# Use + to combine: swe+eng
OCR_LANGUAGE=swe+eng

# ── Folders ─────────────────────────────────────────
# Folder to watch for new receipt images
WATCH_FOLDER=receipts/

# Folder where the Excel output will be saved
OUTPUT_FOLDER=output/

# ── Excel ────────────────────────────────────────────
# Name of the Excel file to write to
EXCEL_FILENAME=receipts.xlsx

# ── Review ───────────────────────────────────────────
# Whether to manually review each receipt before saving (true/false)
REVIEW_MODE=true